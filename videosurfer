function fmtTime(s) {
  if (!isFinite(s)) return '0:00';
  const m = Math.floor(s / 60);
  const sec = Math.floor(s % 60);
  return m + ':' + (sec < 10 ? '0' : '') + sec;
}

function updateAudio() {
  // Active if file is playing OR mic is on
  const isActive = audioPlaying || micActive;
  if (!analyser || !isActive) {
    bassLvl *= 0.9; midLvl *= 0.9; trebLvl *= 0.9;
    return;
  }
  analyser.smoothingTimeConstant = state.audioSmooth;
  analyser.getByteFrequencyData(freqData);
  const nyquist = audioCtx.sampleRate / 2;
  const binHz = nyquist / freqData.length;
  const bassEnd = Math.floor(250 / binHz);
  const midEnd = Math.floor(2000 / binHz);
  let bSum = 0, mSum = 0, tSum = 0;
  let bN = 0, mN = 0, tN = 0;
  for (let i = 1; i < freqData.length; i++) {
    if (i < bassEnd) { bSum += freqData[i]; bN++; }
    else if (i < midEnd) { mSum += freqData[i]; mN++; }
    else { tSum += freqData[i]; tN++; }
  }
  bassLvl = bN ? (bSum / bN) / 255 : 0;
  midLvl = mN ? (mSum / mN) / 255 : 0;
  trebLvl = tN ? (tSum / tN) / 255 : 0;

  if (state.audioSrc === 0 && audioDuration > 0 && !audioScrubbing) {
    const ct = getAudioCurrentTime();
    audioPosSlider.value = ct / audioDuration;
    document.getElementById('audioPosV').textContent = fmtTime(ct);
  }
}



// Shared rate-shaping: maps the linear rate slider (0.01-5) to a perceptually
// logarithmic Hz value, so slow rates get most of the slider travel.
function shapeRateHz(r) {
  const minR = 0.01, maxR = 5;
  if (r <= minR) return 0;
  const tNorm = (r - minR) / (maxR - minR);
  return minR * Math.pow(maxR / minR, tNorm);
}

function bindSlider(id) {
  const el = document.getElementById(id);
  const valEl = document.getElementById(id + 'V');
  const isRate = (id === 'lfo1Rate' || id === 'lfo2Rate');
  const update = () => {
    const v = parseFloat(el.value);
    state[id] = v;
    if (isRate) {
      // Show the actual Hz the log curve produces, not the raw slider position
      const hz = shapeRateHz(v);
      valEl.textContent = hz === 0 ? 'off' : (hz < 0.1 ? hz.toFixed(3) : hz.toFixed(2));
    } else {
      valEl.textContent = v.toFixed(Math.abs(v) >= 10 ? 1 : 2);
    }
  };
  el.addEventListener('input', update);
  update();
}
