const audioPosSlider = document.getElementById('audioPos');
audioPosSlider.addEventListener('input', (e) => {
  if (!audioLoaded) return;
  audioScrubbing = true;
  audioPauseOffset = parseFloat(e.target.value) * audioDuration;
