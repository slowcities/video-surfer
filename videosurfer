<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<title>Video Surfer</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  html, body { width: 100%; height: 100%; overflow: hidden; background: #000; font-family: -apple-system, BlinkMacSystemFont, "SF Mono", Menlo, monospace; color: #d0d0d0; touch-action: none; }
  #canvas { display: block; width: 100vw; height: 100vh; position: fixed; top: 0; left: 0; z-index: 1; }
  #ui {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 10;
    background: rgba(8, 8, 10, 0.92);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(255,255,255,0.08);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    max-height: 70vh; overflow-y: auto; padding-bottom: env(safe-area-inset-bottom);
  }
  #ui.hidden { transform: translateY(calc(100% - 44px)); }
  #toggle-bar {
    height: 44px; display: flex; align-items: center; justify-content: space-between;
    padding: 0 16px; cursor: pointer; user-select: none;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  #toggle-bar .title { font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: #888; font-weight: 600; }
  #toggle-bar .chevron { font-size: 14px; color: #666; transition: transform 0.3s; }
  #ui.hidden #toggle-bar .chevron { transform: rotate(180deg); }
  #panels { padding: 12px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (max-width: 380px) { #panels { grid-template-columns: 1fr; } }
  .panel {
    background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px; padding: 10px;
  }
  .panel h3 {
    font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase;
    color: #6a9b6a; margin-bottom: 8px; font-weight: 700;
  }
  .panel.osc1 h3 { color: #c97a7a; }
  .panel.osc2 h3 { color: #7a9bc9; }
  .panel.lfo1 h3 { color: #c9a87a; }
  .panel.lfo2 h3 { color: #b07ac9; }
  .panel.rutt h3 { color: #7ac9b0; }
  .panel.fb h3 { color: #c97ac9; }
  .panel.bg h3 { color: #c9c97a; }
  .row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .row:last-child { margin-bottom: 0; }
  .row label { font-size: 10px; color: #aaa; width: 48px; flex-shrink: 0; text-transform: uppercase; letter-spacing: 0.05em; }
  .row .val { font-size: 10px; color: #ddd; width: 38px; text-align: right; font-variant-numeric: tabular-nums; flex-shrink: 0; }
  input[type="range"] {
    flex: 1; height: 24px; -webkit-appearance: none; appearance: none;
    background: transparent; outline: none; margin: 0; padding: 0;
  }
  input[type="range"]::-webkit-slider-runnable-track {
    height: 3px; background: rgba(255,255,255,0.12); border-radius: 2px;
  }
  input[type="range"]::-moz-range-track {
    height: 3px; background: rgba(255,255,255,0.12); border-radius: 2px;
  }
  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none; width: 20px; height: 20px; border-radius: 50%;
    background: #d0d0d0; margin-top: -8.5px; cursor: pointer;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.3);
  }
  input[type="range"]::-moz-range-thumb {
    width: 20px; height: 20px; border-radius: 50%; background: #d0d0d0;
    border: none; cursor: pointer; box-shadow: 0 0 0 1px rgba(0,0,0,0.3);
  }
  .seg { display: flex; gap: 0; background: rgba(0,0,0,0.3); border-radius: 6px; padding: 2px; }
  .seg button {
    flex: 1; padding: 6px 4px; font-size: 9px; background: transparent;
    color: #888; border: none; border-radius: 4px; cursor: pointer;
    text-transform: uppercase; letter-spacing: 0.05em; font-family: inherit;
    transition: all 0.15s;
  }
  .seg button.active { background: rgba(255,255,255,0.1); color: #fff; }
  .seg.roygbiv button { font-weight: 700; font-size: 11px; padding: 6px 2px; }

  /* Drag-and-drop audio overlay */
  #dropOverlay {
    position: fixed; inset: 0; z-index: 100;
    background: rgba(122, 201, 176, 0.15);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    border: 4px dashed rgba(122, 201, 176, 0.8);
    display: none; align-items: center; justify-content: center;
    pointer-events: none;
    color: #7ac9b0; font-family: inherit; font-size: 18px;
    text-transform: uppercase; letter-spacing: 0.2em; font-weight: 700;
  }
  #dropOverlay.active { display: flex; }

  /* MIDI learn states */
  .midi-armed { outline: 2px dashed #c97ac9 !important; outline-offset: 2px; animation: midi-pulse 1s ease-in-out infinite; }
  @keyframes midi-pulse { 0%,100% { outline-color: #c97ac9; } 50% { outline-color: #ff66ff; } }
  .midi-mapped { box-shadow: inset 0 0 0 1px rgba(201, 122, 201, 0.5) !important; }
  .midi-learning .row label, .midi-learning .seg-row label { cursor: pointer; }
  .midi-learning input[type="range"], .midi-learning .seg button, .midi-learning #bloomBtn { cursor: crosshair; }
  .seg-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .seg-row label { font-size: 10px; color: #aaa; width: 48px; flex-shrink: 0; text-transform: uppercase; letter-spacing: 0.05em; }
  .seg-row .seg { flex: 1; }
  #hideUI {
    position: fixed; top: 12px; right: 12px; z-index: 11;
    width: 36px; height: 36px; border-radius: 50%;
    background: rgba(0,0,0,0.4); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.15); color: #ccc;
    font-size: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: opacity 0.3s;
  }
  #hideUI.dim { opacity: 0.15; }
  #hideUI:active { opacity: 1; }
</style>
</head>
<body>
<canvas id="canvas"></canvas>
<button id="hideUI" title="Hide controls">◐</button>
<div id="dropOverlay">Drop audio file to load</div>

<div id="ui">
  <div id="toggle-bar">
    <span class="title">Video Surfer</span>
    <span class="chevron">▼</span>
  </div>
  <div id="panels">

    <div class="panel osc1">
      <h3>Oscillator 1</h3>
      <div class="seg-row"><label>Wave</label>
        <div class="seg" data-param="osc1Wave">
          <button data-val="0" class="active">Sin</button>
          <button data-val="1">Tri</button>
          <button data-val="2">Sqr</button>
          <button data-val="3">Saw</button>
        </div>
      </div>
      <div class="seg-row"><label>Axis</label>
        <div class="seg" data-param="osc1Axis">
          <button data-val="0" class="active">H</button>
          <button data-val="1">V</button>
          <button data-val="2">Rad</button>
          <button data-val="3">Diag</button>
        </div>
      </div>
      <div class="row"><label>Freq</label><input type="range" id="osc1Freq" min="0.5" max="80" step="0.1" value="8"><span class="val" id="osc1FreqV">8.0</span></div>
      <div class="row"><label>Phase</label><input type="range" id="osc1Phase" min="0" max="6.28" step="0.01" value="0"><span class="val" id="osc1PhaseV">0.00</span></div>
      <div class="row"><label>Amp</label><input type="range" id="osc1Amp" min="0" max="1" step="0.01" value="0.8"><span class="val" id="osc1AmpV">0.80</span></div>
      <div class="row"><label>Drift</label><input type="range" id="osc1Drift" min="-2" max="2" step="0.001" value="0"><span class="val" id="osc1DriftV">0.00</span></div>
      <div class="row"><label>Hue</label><input type="range" id="osc1Hue" min="0" max="1" step="0.001" value="0"><span class="val" id="osc1HueV">0.00</span></div>
      <div class="seg-row"><label>Color</label>
        <div class="seg roygbiv" data-target="osc1Hue">
          <button data-val="0.00" style="color:#ff5555">R</button>
          <button data-val="0.08" style="color:#ff9944">O</button>
          <button data-val="0.16" style="color:#ffdd33">Y</button>
          <button data-val="0.33" style="color:#55dd55">G</button>
          <button data-val="0.58" style="color:#5599ff">B</button>
          <button data-val="0.72" style="color:#9966ff">I</button>
          <button data-val="0.83" style="color:#dd66dd">V</button>
        </div>
      </div>
      <div class="seg-row"><label>FM</label>
        <div class="seg" data-param="fmOn">
          <button data-val="0" class="active">Off</button>
          <button data-val="1">On</button>
        </div>
      </div>
      <div class="row"><label>FM Amt</label><input type="range" id="fmAmt" min="0" max="3" step="0.01" value="0.5"><span class="val" id="fmAmtV">0.50</span></div>
      <div class="row"><label>FM Mod</label><input type="range" id="fmMod" min="0" max="1" step="0.01" value="0"><span class="val" id="fmModV">0.00</span></div>
    </div>

    <div class="panel osc2">
      <h3>Oscillator 2</h3>
      <div class="seg-row"><label>Wave</label>
        <div class="seg" data-param="osc2Wave">
          <button data-val="0" class="active">Sin</button>
          <button data-val="1">Tri</button>
          <button data-val="2">Sqr</button>
          <button data-val="3">Saw</button>
        </div>
      </div>
      <div class="seg-row"><label>Axis</label>
        <div class="seg" data-param="osc2Axis">
          <button data-val="0">H</button>
          <button data-val="1" class="active">V</button>
          <button data-val="2">Rad</button>
          <button data-val="3">Diag</button>
        </div>
      </div>
      <div class="row"><label>Freq</label><input type="range" id="osc2Freq" min="0.5" max="80" step="0.1" value="12"><span class="val" id="osc2FreqV">12.0</span></div>
      <div class="row"><label>Phase</label><input type="range" id="osc2Phase" min="0" max="6.28" step="0.01" value="0"><span class="val" id="osc2PhaseV">0.00</span></div>
      <div class="row"><label>Amp</label><input type="range" id="osc2Amp" min="0" max="1" step="0.01" value="0.6"><span class="val" id="osc2AmpV">0.60</span></div>
      <div class="row"><label>Drift</label><input type="range" id="osc2Drift" min="-2" max="2" step="0.001" value="0"><span class="val" id="osc2DriftV">0.00</span></div>
      <div class="row"><label>Hue</label><input type="range" id="osc2Hue" min="0" max="1" step="0.001" value="0.58"><span class="val" id="osc2HueV">0.58</span></div>
      <div class="seg-row"><label>Color</label>
        <div class="seg roygbiv" data-target="osc2Hue">
          <button data-val="0.00" style="color:#ff5555">R</button>
          <button data-val="0.08" style="color:#ff9944">O</button>
          <button data-val="0.16" style="color:#ffdd33">Y</button>
          <button data-val="0.33" style="color:#55dd55">G</button>
          <button data-val="0.58" style="color:#5599ff">B</button>
          <button data-val="0.72" style="color:#9966ff">I</button>
          <button data-val="0.83" style="color:#dd66dd">V</button>
        </div>
      </div>
      <div class="seg-row"><label>Clr Drift</label>
        <div class="seg" data-param="osc2ClrDrift">
          <button data-val="0" class="active">Off</button>
          <button data-val="1">O1</button>
          <button data-val="2">O2</button>
          <button data-val="3">Both</button>
        </div>
      </div>
    </div>

    <div class="panel lfo1">
      <h3>LFO 1</h3>
      <div class="seg-row"><label>Wave</label>
        <div class="seg" data-param="lfo1Wave">
          <button data-val="0" class="active">Sin</button>
          <button data-val="1">Tri</button>
          <button data-val="2">Sqr</button>
          <button data-val="3">S/H</button>
        </div>
      </div>
      <div class="seg-row"><label>Dest</label>
        <div class="seg" data-param="lfo1Dest">
          <button data-val="0" class="active">O1F</button>
          <button data-val="1">O1H</button>
          <button data-val="2">FBAMT</button>
          <button data-val="3">FBHUE</button>
        </div>
      </div>
      <div class="row"><label>Rate</label><input type="range" id="lfo1Rate" min="0.01" max="5" step="0.01" value="0"><span class="val" id="lfo1RateV">0.00</span></div>
      <div class="row"><label>Depth</label><input type="range" id="lfo1Depth" min="0" max="1" step="0.01" value="0"><span class="val" id="lfo1DepthV">0.00</span></div>
    </div>

    <div class="panel lfo2">
      <h3>LFO 2</h3>
      <div class="seg-row"><label>Wave</label>
        <div class="seg" data-param="lfo2Wave">
          <button data-val="0" class="active">Sin</button>
          <button data-val="1">Tri</button>
          <button data-val="2">Sqr</button>
          <button data-val="3">S/H</button>
        </div>
      </div>
      <div class="seg-row"><label>Dest</label>
        <div class="seg" data-param="lfo2Dest">
          <button data-val="0" class="active">O2F</button>
          <button data-val="1">O2H</button>
          <button data-val="2">FBZM</button>
          <button data-val="3">FBROT</button>
        </div>
      </div>
      <div class="row"><label>Rate</label><input type="range" id="lfo2Rate" min="0.01" max="5" step="0.01" value="0"><span class="val" id="lfo2RateV">0.00</span></div>
      <div class="row"><label>Depth</label><input type="range" id="lfo2Depth" min="0" max="1" step="0.01" value="0"><span class="val" id="lfo2DepthV">0.00</span></div>
    </div>

    <div class="panel rutt">
      <h3>Rutt / Etra</h3>
      <div class="seg-row"><label>Mode</label>
        <div class="seg" data-param="ruttMode">
          <button data-val="0">Wire</button>
          <button data-val="1">Solid</button>
          <button data-val="2" class="active">Off</button>
        </div>
      </div>
      <div class="row"><label>Disp</label><input type="range" id="ruttDisp" min="0" max="2" step="0.01" value="0.6"><span class="val" id="ruttDispV">0.60</span></div>
      <div class="row"><label>Tilt</label><input type="range" id="ruttTilt" min="-1.2" max="1.2" step="0.01" value="0.45"><span class="val" id="ruttTiltV">0.45</span></div>
      <div class="row"><label>Rot</label><input type="range" id="ruttRot" min="-3.14" max="3.14" step="0.01" value="0"><span class="val" id="ruttRotV">0.00</span></div>
      <div class="row"><label>Zoom</label><input type="range" id="ruttZoom" min="0.5" max="2.5" step="0.01" value="1.2"><span class="val" id="ruttZoomV">1.20</span></div>
    </div>

    <div class="panel fb">
      <h3>Feedback</h3>
      <div class="row"><label>Amount</label><input type="range" id="fbAmount" min="0" max="0.99" step="0.01" value="0"><span class="val" id="fbAmountV">0.00</span></div>
      <div class="row"><label>Zoom</label><input type="range" id="fbZoom" min="0.85" max="1.15" step="0.001" value="1.01"><span class="val" id="fbZoomV">1.01</span></div>
      <div class="row"><label>Rot</label><input type="range" id="fbRot" min="-0.15" max="0.15" step="0.001" value="0.01"><span class="val" id="fbRotV">0.01</span></div>
      <div class="row"><label>Hue</label><input type="range" id="fbHue" min="-0.05" max="0.05" step="0.001" value="0"><span class="val" id="fbHueV">0.00</span></div>
      <div class="seg-row" style="margin-top: 8px;"><label>Burst</label>
        <div class="seg" data-param="bloomStyle">
          <button data-val="0" class="active">White</button>
          <button data-val="1">Color</button>
          <button data-val="2">Geom</button>
        </div>
      </div>
      <div class="row"><label>Intensity</label><input type="range" id="bloomIntensity" min="0" max="1" step="0.01" value="0.7"><span class="val" id="bloomIntensityV">0.70</span></div>
      <button id="bloomBtn" style="width: 100%; padding: 14px; margin-top: 6px; background: rgba(201, 122, 201, 0.15); border: 1px solid rgba(201, 122, 201, 0.4); color: #c97ac9; border-radius: 6px; font-family: inherit; font-size: 12px; text-transform: uppercase; letter-spacing: 0.15em; font-weight: 700; cursor: pointer; user-select: none; -webkit-user-select: none; touch-action: manipulation;">Hold to Burst</button>
    </div>

    <div class="panel bg" style="grid-column: 1 / -1;">
      <h3>Video Input</h3>
      <div class="seg-row"><label>Source</label>
        <div class="seg" data-param="vidSrc">
          <button data-val="0" class="active">Camera</button>
          <button data-val="1">Video</button>
        </div>
      </div>
      <div class="seg-row"><label>Mode</label>
        <div class="seg" data-param="camMode">
          <button data-val="0" class="active">Off</button>
          <button data-val="1">BG</button>
          <button data-val="2">Disp</button>
          <button data-val="3">Both</button>
        </div>
      </div>
      <div class="row"><label>Mix</label><input type="range" id="camMix" min="0" max="1" step="0.01" value="0.7"><span class="val" id="camMixV">0.70</span></div>
      <div class="row"><label>Bright</label><input type="range" id="camBright" min="0" max="2" step="0.01" value="1"><span class="val" id="camBrightV">1.00</span></div>

      <div id="camCtrls">
        <div class="seg-row" style="margin-top: 8px;"><label>Device</label>
          <select id="camDevice" style="flex: 1; padding: 7px 8px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #ddd; border-radius: 6px; font-family: inherit; font-size: 10px; cursor: pointer; -webkit-appearance: none; appearance: none;">
            <option value="">Default / by facing</option>
          </select>
        </div>
        <div class="seg-row" style="margin-top: 8px;"><label>Facing</label>
          <div class="seg" data-param="camFacing">
            <button data-val="0" class="active">Rear</button>
            <button data-val="1">Front</button>
          </div>
        </div>
        <div style="display: flex; gap: 6px; margin-top: 8px;">
          <button id="camStart" style="flex: 1; padding: 8px; background: rgba(122, 201, 176, 0.15); border: 1px solid rgba(122, 201, 176, 0.4); color: #7ac9b0; border-radius: 6px; font-family: inherit; font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer;">Enable Camera</button>
          <button id="camMirror" style="flex: 0 0 auto; padding: 8px 12px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); color: #aaa; border-radius: 6px; font-family: inherit; font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer;">Mirror: Auto</button>
        </div>
      </div>

      <div id="vidCtrls" style="display: none;">
        <div style="display: flex; gap: 6px; margin-top: 8px;">
          <label for="vidFile" id="vidFileLabel" style="flex: 1; padding: 8px; background: rgba(122, 201, 176, 0.15); border: 1px solid rgba(122, 201, 176, 0.4); color: #7ac9b0; border-radius: 6px; font-family: inherit; font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; text-align: center;">Load or Drop Video</label>
          <input type="file" id="vidFile" accept="video/*" style="display: none;">
          <button id="vidPlay" style="flex: 0 0 auto; padding: 8px 16px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); color: #aaa; border-radius: 6px; font-family: inherit; font-size: 14px; cursor: pointer;" disabled>▶</button>
          <button id="vidLoop" style="flex: 0 0 auto; padding: 8px 12px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); color: #aaa; border-radius: 6px; font-family: inherit; font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer;">Loop</button>
        </div>
        <div class="row"><label>Pos</label><input type="range" id="vidPos" min="0" max="1" step="0.001" value="0" disabled><span class="val" id="vidPosV">0:00</span></div>
        <div style="display: flex; gap: 6px; margin-top: 6px;">
          <button id="vidMute" style="flex: 1; padding: 8px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); color: #aaa; border-radius: 6px; font-family: inherit; font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer;">Audio: Muted</button>
        </div>
      </div>
    </div>

    <div class="panel bg" style="grid-column: 1 / -1;">
      <h3>Audio Reactivity</h3>
      <div class="seg-row"><label>Source</label>
        <div class="seg" data-param="audioSrc">
          <button data-val="0" class="active">File</button>
          <button data-val="1">Mic</button>
        </div>
      </div>
      <div id="audioFileControls">
      <div style="display: flex; gap: 6px; margin-bottom: 8px;">
        <label for="audioFile" id="audioFileLabel" style="flex: 1; padding: 8px; background: rgba(122, 201, 176, 0.15); border: 1px solid rgba(122, 201, 176, 0.4); color: #7ac9b0; border-radius: 6px; font-family: inherit; font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; text-align: center;">Load or Drop Audio</label>
        <input type="file" id="audioFile" accept="audio/*" style="display: none;">
