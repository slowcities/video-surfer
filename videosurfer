// ---------- LFO helpers ----------
let shTime = [0, 0];
let shVal = [0, 0];
function lfo(t, rate, wave, idx) {
  const phase = t * rate;
  if (wave < 0.5) return Math.sin(phase * 2 * Math.PI);
  if (wave < 1.5) { // triangle
    const p = (phase) % 1;
    return Math.abs(p * 2 - 1) * 2 - 1;
  }
  if (wave < 2.5) return Math.sin(phase * 2 * Math.PI) > 0 ? 1 : -1;
  // sample & hold
  const period = 1 / Math.max(rate, 0.001);
  if (t - shTime[idx] > period) {
    shTime[idx] = t;
    shVal[idx] = Math.random() * 2 - 1;
  }
  return shVal[idx];
}

// ---------- Camera ----------
let videoEl = null;
let videoTexture = null;
let camStream = null;
let camActive = false;

async function startCamera(facing) {
  // Stop existing stream
  if (camStream) {
    camStream.getTracks().forEach(t => t.stop());
    camStream = null;
  }
  try {
    let constraints;
    if (state.camDeviceId) {
      // Explicit device selected (USB webcam, capture card, etc.)
      constraints = {
        video: {
          deviceId: { exact: state.camDeviceId },
          width: { ideal: 1280 },
          height: { ideal: 720 }
        },
        audio: false
      };
    } else {
      // Fall back to facing mode (natural on phones)
      constraints = {
        video: {
          facingMode: facing === 1 ? 'user' : 'environment',
          width: { ideal: 1280 },
          height: { ideal: 720 }
        },
        audio: false
      };
    }
    camStream = await navigator.mediaDevices.getUserMedia(constraints);
    if (!videoEl) {
      videoEl = document.createElement('video');
      videoEl.setAttribute('playsinline', '');
      videoEl.setAttribute('muted', '');
      videoEl.muted = true;
      videoEl.style.display = 'none';
      document.body.appendChild(videoEl);
    }
    videoEl.srcObject = camStream;
    await videoEl.play();
    videoTexture = new THREE.VideoTexture(videoEl);
    videoTexture.minFilter = THREE.LinearFilter;
    videoTexture.magFilter = THREE.LinearFilter;
    videoTexture.format = THREE.RGBAFormat;
    if (state.vidSrc === 0) {
      patternMat.uniforms.uCam.value = videoTexture;
      ruttUniforms.uCam.value = videoTexture;
    }
    camActive = true;
    document.getElementById('camStart').textContent = 'Camera On';
    document.getElementById('camStart').style.background = 'rgba(122, 201, 176, 0.3)';
    // Now that permission is granted, device labels are available — refresh the list
    refreshCameraDevices();
    return true;
  } catch (err) {
    alert('Camera access failed: ' + err.message);
    return false;
  }
}

function getCamAspect() {
  if (videoEl && videoEl.videoWidth > 0) {
    return videoEl.videoWidth / videoEl.videoHeight;
  }
  return 16 / 9;
}

// Enumerate cameras and populate the device dropdown. Device labels are only
// exposed by the browser after camera permission has been granted at least once.
async function refreshCameraDevices() {
  if (!navigator.mediaDevices || !navigator.mediaDevices.enumerateDevices) return;
  try {
    const devices = await navigator.mediaDevices.enumerateDevices();
    const cams = devices.filter(d => d.kind === 'videoinput');
    const sel = document.getElementById('camDevice');
    const prev = sel.value;
    // Rebuild options
    sel.innerHTML = '<option value="">Default / by facing</option>';
    cams.forEach((cam, i) => {
      const opt = document.createElement('option');
      opt.value = cam.deviceId;
      // Labels are empty until permission granted; fall back to a generic name
      opt.textContent = cam.label || ('Camera ' + (i + 1));
      sel.appendChild(opt);
    });
    // Restore previous selection if still present
    if (prev && cams.some(c => c.deviceId === prev)) sel.value = prev;
  } catch (err) {
    console.error('Device enumeration failed:', err);
  }
}

