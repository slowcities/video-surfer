let midiAccess = null;
let midiLearning = false;       // is "MIDI Learn" mode on?
let midiArmedTarget = null;     // {kind: 'slider'|'seg'|'button', id, ...}
let midiMappings = {};          // key: "type-status-cc/note" → target descriptor
// Pickup state per slider id: tracks whether incoming MIDI has "caught up" to current value
let midiPickup = {};            // {sliderId: {captured: bool, lastMidi: number}}
let bloomAutoReleaseTimer = null; // Used by MIDI to auto-release bloom for toggle-mode pads
const MIDI_STORAGE_KEY = 'analogVideoSynth.midiMappings.v1';

// Catalogue of bindable targets (sliders, segment groups, the bloom button)
function getBindableTargets() {
  const targets = [];
  // Sliders: any <input type="range"> with an id
  document.querySelectorAll('input[type="range"]').forEach(el => {
    targets.push({ kind: 'slider', id: el.id, el });
  });
  // Segment groups (data-param)
  document.querySelectorAll('.seg[data-param]').forEach(seg => {
    targets.push({ kind: 'seg', id: seg.dataset.param, el: seg });
  });
  // Bloom button
  targets.push({ kind: 'bloom', id: 'bloomBtn', el: document.getElementById('bloomBtn') });
  return targets;
}

function loadMidiMappings() {
  try {
    const raw = localStorage.getItem(MIDI_STORAGE_KEY);
    if (raw) midiMappings = JSON.parse(raw);
  } catch (e) { midiMappings = {}; }
  refreshMappedHighlights();
}

function saveMidiMappings() {
  try { localStorage.setItem(MIDI_STORAGE_KEY, JSON.stringify(midiMappings)); } catch (e) {}
}

function refreshMappedHighlights() {
  // Clear all
  document.querySelectorAll('.midi-mapped').forEach(el => el.classList.remove('midi-mapped'));
  // Apply to currently-mapped target elements
  const mappedIds = new Set();
  for (const key in midiMappings) mappedIds.add(midiMappings[key].kind + ':' + midiMappings[key].id);
  getBindableTargets().forEach(t => {
    if (mappedIds.has(t.kind + ':' + t.id)) t.el.classList.add('midi-mapped');
  });
}

function midiMessageKey(status, dataByte) {
  // status: 0x90 (note on), 0x80 (note off), 0xB0 (CC), etc. Strip channel.
  const type = (status & 0xf0);
  const ch = (status & 0x0f);
  return type + '-' + ch + '-' + dataByte;
}

function setMidiStatus(text, color) {
  const el = document.getElementById('midiStatus');
  el.textContent = text;
  el.style.color = color || '#888';
}

function setMidiActivity(text) {
  document.getElementById('midiActivity').textContent = text;
}

async function enableMidi() {
  if (!navigator.requestMIDIAccess) {
    setMidiStatus('MIDI not supported in this browser', '#c97a7a');
    return;
  }
  try {
    midiAccess = await navigator.requestMIDIAccess({ sysex: false });
    bindMidiInputs();
    midiAccess.onstatechange = () => bindMidiInputs();
    document.getElementById('midiLearn').disabled = false;
    document.getElementById('midiClear').disabled = false;
    document.getElementById('midiEnable').textContent = 'Enabled';
    document.getElementById('midiEnable').style.background = 'rgba(122, 201, 176, 0.3)';
    loadMidiMappings();
  } catch (err) {
    setMidiStatus('MIDI permission denied', '#c97a7a');
    console.error('MIDI error:', err);
  }
}

function bindMidiInputs() {
  if (!midiAccess) return;
  const inputs = Array.from(midiAccess.inputs.values());
  inputs.forEach(input => { input.onmidimessage = handleMidiMessage; });
  if (inputs.length === 0) {
    setMidiStatus('MIDI: No devices', '#c9a87a');
  } else if (inputs.length === 1) {
    setMidiStatus('MIDI: ' + (inputs[0].name || 'connected'), '#7ac9b0');
  } else {
    setMidiStatus('MIDI: ' + inputs.length + ' devices', '#7ac9b0');
  }
}

function handleMidiMessage(e) {
  const [status, d1, d2] = e.data;
  const type = status & 0xf0;
  // Show activity
  if (type === 0xB0) setMidiActivity('CC ' + d1 + ' = ' + d2 + ' ch' + ((status & 0x0f) + 1));
  else if (type === 0x90 && d2 > 0) setMidiActivity('Note On ' + d1 + ' vel ' + d2);
  else if (type === 0x80 || (type === 0x90 && d2 === 0)) setMidiActivity('Note Off ' + d1);

  const key = midiMessageKey(status, d1);

  // If learning + a target is armed, bind this message to it
  if (midiLearning && midiArmedTarget) {
    // Note off shouldn't create a binding by itself
    if (type === 0x80 || (type === 0x90 && d2 === 0)) return;
    midiMappings[key] = {
      kind: midiArmedTarget.kind,
      id: midiArmedTarget.id,
      type: type, // 0xB0 = CC, 0x90 = note
      ch: status & 0x0f,
      data1: d1
    };
    // If the target was also bound to a different message previously, remove the old binding
    for (const k in midiMappings) {
      if (k !== key && midiMappings[k].kind === midiArmedTarget.kind && midiMappings[k].id === midiArmedTarget.id) {
        delete midiMappings[k];
      }
    }
    saveMidiMappings();
    // Disarm and clear highlight
    midiArmedTarget.el.classList.remove('midi-armed');
    midiArmedTarget = null;
    refreshMappedHighlights();
    setMidiActivity('Mapped to ' + (type === 0xB0 ? 'CC ' + d1 : 'Note ' + d1));
    return;
  }

  // Otherwise look up the mapping and apply
  const mapping = midiMappings[key];
  if (!mapping) return;
  applyMidiToTarget(mapping, type, d1, d2);
}

function applyMidiToTarget(mapping, type, d1, d2) {
  if (mapping.kind === 'slider') {
    const slider = document.getElementById(mapping.id);
    if (!slider) return;
    const min = parseFloat(slider.min);
    const max = parseFloat(slider.max);
    let incoming;
    if (type === 0xB0) {
      // CC: 0-127 normalized
      const t = d2 / 127;
      // Use log mapping for wide positive ranges (e.g. frequencies),
      // which gives perceptually-even steps instead of huge jumps at the low end.
      const useLog = min > 0 && max / min > 50;
      if (useLog) {
        incoming = min * Math.pow(max / min, t);
      } else {
        incoming = min + t * (max - min);
      }
    } else {
      return;
    }
    // Pickup mode: ignore until incoming crosses the current value
    const cur = parseFloat(slider.value);
    const pick = midiPickup[mapping.id] || (midiPickup[mapping.id] = { captured: false, lastMidi: incoming });
    if (!pick.captured) {
      const useLog = min > 0 && max / min > 50;
      // Compare in normalized (log or linear) space so threshold is even across range
      const norm = (v) => useLog ? Math.log(v / min) / Math.log(max / min) : (v - min) / (max - min);
      const curN = norm(cur);
      const incN = norm(incoming);
      const lastN = norm(pick.lastMidi);
      const prevSide = lastN >= curN;
      const newSide = incN >= curN;
      if (Math.abs(incN - curN) < 0.02 || prevSide !== newSide) {
        pick.captured = true;
      }
      pick.lastMidi = incoming;
      if (!pick.captured) return;
    }
    pick.lastMidi = incoming;
    slider.value = incoming;
    slider.dispatchEvent(new Event('input'));
  } else if (mapping.kind === 'seg') {
    // Segment: advance to next value on note-on or on CC threshold cross
    const seg = document.querySelector('.seg[data-param="' + mapping.id + '"]');
    if (!seg) return;
    if (type === 0x90 && d2 > 0) {
      const buttons = Array.from(seg.querySelectorAll('button'));
      const activeIdx = buttons.findIndex(b => b.classList.contains('active'));
      const nextIdx = (activeIdx + 1) % buttons.length;
      buttons[nextIdx].click();
    } else if (type === 0xB0) {
      // Map CC range to button index
      const buttons = Array.from(seg.querySelectorAll('button'));
      const idx = Math.min(buttons.length - 1, Math.floor((d2 / 128) * buttons.length));
      if (!buttons[idx].classList.contains('active')) buttons[idx].click();
    }
  } else if (mapping.kind === 'bloom') {
    if (type === 0x90 && d2 > 0) {
      // Note On
      if (bloomTarget === 1) {
        // Already blooming — this Note On is a toggle-pad re-tap, treat as release
        bloomUp(null);
        if (bloomAutoReleaseTimer) { clearTimeout(bloomAutoReleaseTimer); bloomAutoReleaseTimer = null; }
      } else {
        bloomDown({ preventDefault: () => {} });
        // Schedule auto-release in case the controller never sends Note Off (toggle mode)
        if (bloomAutoReleaseTimer) clearTimeout(bloomAutoReleaseTimer);
        bloomAutoReleaseTimer = setTimeout(() => {
          if (bloomTarget === 1) bloomUp(null);
          bloomAutoReleaseTimer = null;
        }, 200);
      }
    } else if (type === 0x80 || (type === 0x90 && d2 === 0)) {
      // Note Off — controller is momentary, release immediately and cancel auto-release
      if (bloomAutoReleaseTimer) { clearTimeout(bloomAutoReleaseTimer); bloomAutoReleaseTimer = null; }
      bloomUp(null);
    } else if (type === 0xB0) {
      // CC: above 64 = held, below = released
      if (d2 >= 64 && bloomTarget === 0) bloomDown({ preventDefault: () => {} });
      else if (d2 < 64 && bloomTarget === 1) bloomUp(null);
    }
  }
}

// Arming targets when in Learn mode — click any control to arm it.
function armTarget(target) {
  if (midiArmedTarget) midiArmedTarget.el.classList.remove('midi-armed');
  midiArmedTarget = target;
  target.el.classList.add('midi-armed');
  setMidiActivity('Move a MIDI control to bind "' + target.id + '"');
}

function setupLearnClickHandlers() {
  // Use capture phase so clicks during Learn don't actually trigger the control
  document.addEventListener('click', (e) => {
    if (!midiLearning) return;
    // Find which bindable target was clicked
    const targets = getBindableTargets();
    for (const t of targets) {
      if (t.el === e.target || t.el.contains(e.target)) {
        // For segments, the click is on a child button — still arm the whole seg
        e.preventDefault();
        e.stopPropagation();
        armTarget(t);
        return;
      }
    }
  }, true); // capture
  // Also intercept range inputs (which fire 'input' not 'click')
  document.addEventListener('mousedown', (e) => {
    if (!midiLearning) return;
    if (e.target && e.target.matches('input[type="range"]')) {
      e.preventDefault();
      e.stopPropagation();
      armTarget({ kind: 'slider', id: e.target.id, el: e.target });
    }
  }, true);
}

