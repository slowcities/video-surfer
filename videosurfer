});

// Drag-and-drop anywhere on the window — avoids the focus-loss / fullscreen-exit
// problem that the OS file picker causes.
const dropOverlay = document.getElementById('dropOverlay');
let dragDepth = 0; // count nested dragenter/leave events to avoid flicker
function isAudioDrag(e) {
  if (!e.dataTransfer) return false;
  // Some browsers don't populate types until drop. Be lenient: any file drag qualifies.
  const types = Array.from(e.dataTransfer.types || []);
  return types.includes('Files') || types.includes('application/x-moz-file');
}
window.addEventListener('dragenter', (e) => {
  if (!isAudioDrag(e)) return;
  e.preventDefault();
  dragDepth++;
  dropOverlay.classList.add('active');
});
window.addEventListener('dragover', (e) => {
  if (!isAudioDrag(e)) return;
  e.preventDefault();
  e.dataTransfer.dropEffect = 'copy';
});
window.addEventListener('dragleave', (e) => {
  if (!isAudioDrag(e)) return;
  dragDepth = Math.max(0, dragDepth - 1);
  if (dragDepth === 0) dropOverlay.classList.remove('active');
});
window.addEventListener('drop', (e) => {
  if (!isAudioDrag(e)) return;
  e.preventDefault();
  dragDepth = 0;
  dropOverlay.classList.remove('active');
  const files = e.dataTransfer.files;
  if (!files || files.length === 0) return;
  const arr = Array.from(files);
  // Route by type: audio → audio loader, video → video loader. Kept separate.
  const audioFile = arr.find(f =>
    f.type.startsWith('audio/') || /\.(mp3|wav|m4a|aac|ogg|flac|opus)$/i.test(f.name)
  );
  const videoFile = arr.find(f =>
    f.type.startsWith('video/') || /\.(mp4|webm|mov|m4v|ogv)$/i.test(f.name)
  );
  if (videoFile) {
    loadVideoFile(videoFile);
    // Switch the video panel to Video source so it's immediately usable
    if (state.vidSrc !== 1) {
      setVideoSource(1);
      document.querySelectorAll('[data-param="vidSrc"] button').forEach(b => {
        b.classList.toggle('active', parseInt(b.dataset.val) === 1);
      });
    }
  } else if (audioFile) {
    loadAudioFile(audioFile);
  } else {
    dropOverlay.textContent = 'Not an audio or video file';
    dropOverlay.classList.add('active');
    setTimeout(() => {
      dropOverlay.classList.remove('active');
      dropOverlay.textContent = 'Drop audio file to load';
    }, 1500);
  }
});

document.getElementById('audioPlay').addEventListener('click', async () => {
  if (!audioLoaded) return;
  ensureAudioCtx();
  if (audioCtx.state === 'suspended') {
    try { await audioCtx.resume(); } catch (err) { console.error('Resume failed:', err); }
  }
  if (audioPlaying) {
    stopPlayback(true);
    document.getElementById('audioPlay').textContent = '▶';
  } else {
    let start = audioPauseOffset;
    if (start >= audioDuration - 0.05) start = 0; // wrap if at end
