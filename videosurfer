// ---------- Audio reactivity ----------
let audioCtx = null;
let audioBuffer = null;        // decoded PCM
let audioBufferSource = null;  // current playing source (recreated on each play)
let analyser = null;
let audioGain = null;
let freqData = null;
let bassLvl = 0, midLvl = 0, trebLvl = 0;
let audioLoaded = false;
let audioPlaying = false;
let audioLooping = false;
let audioStartCtxTime = 0;     // AudioContext.currentTime when playback started
let audioPauseOffset = 0;      // seconds into the buffer where we paused
let audioDuration = 0;
let audioRAFLast = 0;
// Mic
let micStream = null;
let micSourceNode = null;
let micGainNode = null;
let micActive = false;
let micAnalyserConnected = false; // is the file source currently connected to analyser?

function ensureAudioCtx() {
  if (audioCtx) return audioCtx;
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  analyser = audioCtx.createAnalyser();
  analyser.fftSize = 1024;
  analyser.smoothingTimeConstant = 0.7;
  audioGain = audioCtx.createGain();
  audioGain.gain.value = state.audioVol;
  // audioGain is the speaker path. analyser is a parallel tap with NO downstream
  // connection to destination — this is the only way to read levels without routing
  // mic input back to the speakers.
  audioGain.connect(audioCtx.destination);
  freqData = new Uint8Array(analyser.frequencyBinCount);
  return audioCtx;
}

function getAudioCurrentTime() {
  if (!audioBuffer) return 0;
  if (audioPlaying) {
    let t = audioPauseOffset + (audioCtx.currentTime - audioStartCtxTime);
    if (audioLooping) t = t % audioDuration;
    else if (t > audioDuration) t = audioDuration;
    return t;
  }
  return audioPauseOffset;
}

function startPlayback(offsetSec) {
  if (!audioBuffer || !audioCtx) return;
  // Stop any existing source
  if (audioBufferSource) {
    try { audioBufferSource.onended = null; audioBufferSource.stop(); } catch (e) {}
    audioBufferSource.disconnect();
    audioBufferSource = null;
  }
  audioBufferSource = audioCtx.createBufferSource();
  audioBufferSource.buffer = audioBuffer;
  audioBufferSource.loop = audioLooping;
  // Split: feed both the analyser (for levels) and audioGain (for speakers)
  audioBufferSource.connect(analyser);
  audioBufferSource.connect(audioGain);
  audioBufferSource.onended = () => {
    // Only fires for non-looping completion or manual stop
    if (!audioLooping && audioPlaying) {
      audioPlaying = false;
      audioPauseOffset = 0;
      document.getElementById('audioPlay').textContent = '▶';
    }
  };
  audioStartCtxTime = audioCtx.currentTime;
  audioPauseOffset = offsetSec;
  audioBufferSource.start(0, offsetSec);
  audioPlaying = true;
}

function stopPlayback(savePosition) {
  if (audioBufferSource) {
    if (savePosition) audioPauseOffset = getAudioCurrentTime();
    try { audioBufferSource.onended = null; audioBufferSource.stop(); } catch (e) {}
    audioBufferSource.disconnect();
    audioBufferSource = null;
  }
  audioPlaying = false;
}

async function loadAudioFile(file) {
  if (!file) return;
  const label = document.getElementById('audioFileLabel');
  label.textContent = 'Decoding...';
  try {
    ensureAudioCtx();
    // Stop anything currently playing from a prior file
    stopPlayback(false);
    audioPauseOffset = 0;
    const arrayBuf = await file.arrayBuffer();
    // Use the promise form on browsers that support it (modern Safari, Chrome, Firefox).
    // Calling with callbacks in addition to using the promise return causes Safari to
    // detach the ArrayBuffer and throw "non-finite" errors. Pick one path.
    audioBuffer = await audioCtx.decodeAudioData(arrayBuf);
    audioDuration = audioBuffer.duration;
    audioLoaded = true;
    const playBtn = document.getElementById('audioPlay');
    playBtn.disabled = false;
    playBtn.style.opacity = '1';
    playBtn.style.color = '#7ac9b0';
    playBtn.style.borderColor = 'rgba(122, 201, 176, 0.4)';
    document.getElementById('audioPos').disabled = false;
    label.textContent = file.name.length > 18 ? file.name.slice(0, 16) + '...' : file.name;
    // If user is currently in file mode, ensure the source toggle is on File
    if (state.audioSrc !== 0) setAudioSource(0);
  } catch (err) {
    console.error('Decode failed:', err);
    label.textContent = 'Decode failed';
    alert('Could not decode audio file: ' + (err.message || err));
  }
}

// File picker (existing input)
document.getElementById('audioFile').addEventListener('change', (e) => {
