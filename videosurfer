// ---- Mic input ----
async function enableMic() {
  if (micActive) return true;
  try {
    ensureAudioCtx();
    if (audioCtx.state === 'suspended') await audioCtx.resume();
    micStream = await navigator.mediaDevices.getUserMedia({
      audio: {
        echoCancellation: false,
        noiseSuppression: false,
        autoGainControl: false
      },
      video: false
    });
    micSourceNode = audioCtx.createMediaStreamSource(micStream);
    micGainNode = audioCtx.createGain();
    micGainNode.gain.value = state.micGain;
    micSourceNode.connect(micGainNode);
    // Connect mic chain to analyser only (NOT to destination — no feedback)
    micGainNode.connect(analyser);
    micActive = true;
    const btn = document.getElementById('micStart');
    btn.textContent = 'Mic On';
    btn.style.background = 'rgba(122, 201, 176, 0.3)';
    return true;
  } catch (err) {
    console.error('Mic enable failed:', err);
    alert('Mic access failed: ' + err.message);
    return false;
  }
}

function disableMic() {
  if (!micActive) return;
  try {
    if (micGainNode) micGainNode.disconnect();
    if (micSourceNode) micSourceNode.disconnect();
  } catch (e) {}
  if (micStream) micStream.getTracks().forEach(t => t.stop());
  micStream = null;
  micSourceNode = null;
  micGainNode = null;
  micActive = false;
  bassLvl = 0; midLvl = 0; trebLvl = 0;
  const btn = document.getElementById('micStart');
  btn.textContent = 'Enable Mic';
  btn.style.background = 'rgba(122, 201, 176, 0.15)';
}

document.getElementById('micStart').addEventListener('click', () => {
  if (micActive) disableMic();
  else enableMic();
});

