<script type="module">
import * as THREE from 'three';

// ---------- State ----------
const state = {
  osc1Wave: 0, osc1Axis: 0, osc1Freq: 8, osc1Phase: 0, osc1Amp: 0.8, osc1Hue: 0, osc1Drift: 0,
  osc2Wave: 0, osc2Axis: 1, osc2Freq: 12, osc2Phase: 0, osc2Amp: 0.6, osc2Hue: 0.58, osc2Drift: 0, osc2ClrDrift: 0,
  lfo1Wave: 0, lfo1Dest: 0, lfo1Rate: 0, lfo1Depth: 0,
  lfo2Wave: 0, lfo2Dest: 0, lfo2Rate: 0, lfo2Depth: 0,
  ruttMode: 2, ruttDisp: 0.6, ruttTilt: 0.45, ruttRot: 0, ruttZoom: 1.2,
  fbAmount: 0, fbZoom: 1.01, fbRot: 0.01, fbHue: 0,
  bgMode: 1, blendMode: 0, oscMix: 0.5, bright: 1, contrast: 1,
  camMode: 0, camFacing: 0, camMix: 0.7, camBright: 1, camMirror: -1,
  camDeviceId: '',
  vidSrc: 0, vidMuted: 1,
  fmOn: 0, fmAmt: 0.5, fmMod: 0,
  audioVol: 0.7, audioSmooth: 0.7,
  audioSrc: 0, micGain: 1,
  bassDest: 0, bassAmt: 0.8,
  midDest: 1, midAmt: 0.5,
  trebDest: 2, trebAmt: 0.4,
  bloomStyle: 0, bloomIntensity: 0.7
};

// ---------- Three.js setup ----------
const canvas = document.getElementById('canvas');
const renderer = new THREE.WebGLRenderer({ canvas, antialias: false, powerPreference: 'high-performance' });
const DPR = Math.min(window.devicePixelRatio, 2);
renderer.setPixelRatio(DPR);

function getSize() { return { w: window.innerWidth, h: window.innerHeight }; }
let { w, h } = getSize();
renderer.setSize(w, h, false);

// Two render targets for ping-pong feedback
function makeRT() {
  return new THREE.WebGLRenderTarget(Math.floor(w * 0.75), Math.floor(h * 0.75), {
    minFilter: THREE.LinearFilter,
    magFilter: THREE.LinearFilter,
    format: THREE.RGBAFormat,
    type: THREE.UnsignedByteType
  });
}
let rtA = makeRT();
let rtB = makeRT();

// Scene 1: generate the oscillator pattern into an offscreen target
const patternScene = new THREE.Scene();
const patternCamera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

const patternMat = new THREE.ShaderMaterial({
  uniforms: {
    uTime: { value: 0 },
    uRes: { value: new THREE.Vector2(w, h) },
    uPrev: { value: null },
    // oscillators
    uO1: { value: new THREE.Vector4(0, 0, 0, 0) }, // wave, axis, freq, phase
    uO1Amp: { value: 0.8 },
    uO2: { value: new THREE.Vector4(0, 1, 0, 0) },
    uO2Amp: { value: 0.6 },
    uOscMix: { value: 0.5 },
    uO1Hue: { value: 0 },
    uO2Hue: { value: 0.58 },
    uBlendMode: { value: 0 },
    uBgMode: { value: 1 },
    uBright: { value: 1 },
    uContrast: { value: 1 },
    // feedback
    uFbAmount: { value: 0 },
    uFbZoom: { value: 1.01 },
    uFbRot: { value: 0.01 },
    uFbHue: { value: 0 },
    uCam: { value: null },
    uCamMode: { value: 0 },
    uCamMix: { value: 0.7 },
    uCamBright: { value: 1 },
    uCamMirror: { value: 0 },
    uCamAspect: { value: 1 },
    uScreenAspect: { value: 1 },
    uFmOn: { value: 0 },
    uFmAmt: { value: 0.5 },
    uBloomActive: { value: 0 },
    uBloomStyle: { value: 0 },
    uBloomIntensity: { value: 0.7 }
  },
  vertexShader: /* glsl */`
    varying vec2 vUv;
    void main() {
      vUv = uv;
      gl_Position = vec4(position, 1.0);
    }
  `,
  fragmentShader: /* glsl */`
    precision highp float;
    varying vec2 vUv;
    uniform float uTime;
    uniform vec2 uRes;
    uniform sampler2D uPrev;
    uniform vec4 uO1; // wave, axis, freq, phase
    uniform float uO1Amp;
    uniform vec4 uO2;
    uniform float uO2Amp;
    uniform float uOscMix;
    uniform float uO1Hue;
    uniform float uO2Hue;
    uniform float uBlendMode;
    uniform float uBgMode;
    uniform float uBright;
    uniform float uContrast;
    uniform float uFbAmount;
    uniform float uFbZoom;
    uniform float uFbRot;
    uniform float uFbHue;
    uniform sampler2D uCam;
    uniform float uCamMode;
    uniform float uCamMix;
    uniform float uCamBright;
    uniform float uCamMirror;
    uniform float uCamAspect;
    uniform float uScreenAspect;
    uniform float uFmOn;
    uniform float uFmAmt;
    uniform float uBloomActive;
    uniform float uBloomStyle;
    uniform float uBloomIntensity;

    const float PI = 3.14159265359;
    const float TAU = 6.28318530718;

    float wave(float x, float type) {
      if (type < 0.5) return sin(x);
      if (type < 1.5) {
        float p = fract(x / TAU);
        return abs(p * 2.0 - 1.0) * 2.0 - 1.0;
      }
      if (type < 2.5) return sin(x) > 0.0 ? 1.0 : -1.0;
      return fract(x / TAU) * 2.0 - 1.0;
    }

    float axisCoord(vec2 uv, float axis) {
      vec2 c = uv - 0.5;
      if (axis < 0.5) return uv.x;
      if (axis < 1.5) return uv.y;
      if (axis < 2.5) return length(c);
      return (uv.x + uv.y) * 0.5;
    }

    // HSV -> RGB
    vec3 hsv2rgb(vec3 c) {
      vec4 K = vec4(1.0, 2.0/3.0, 1.0/3.0, 3.0);
      vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
      return c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
    }

    vec3 hueShift(vec3 col, float h) {
      const vec3 k = vec3(0.57735, 0.57735, 0.57735);
      float cosA = cos(h * TAU);
      return col * cosA + cross(k, col) * sin(h * TAU) + k * dot(k, col) * (1.0 - cosA);
    }

    // Sample camera with cover aspect (crop, never letterbox)
    vec3 sampleCamera(vec2 uv) {
      vec2 cuv = uv;
      // Cover-fit: scale so the camera fills the screen, cropping the longer side
      float screenA = uScreenAspect;
      float camA = uCamAspect;
      if (camA > screenA) {
        // Camera wider than screen: crop horizontally
        float scale = screenA / camA;
        cuv.x = (cuv.x - 0.5) * scale + 0.5;
      } else {
        // Camera taller than screen: crop vertically
        float scale = camA / screenA;
        cuv.y = (cuv.y - 0.5) * scale + 0.5;
      }
      // Mirror horizontally if requested
      if (uCamMirror > 0.5) cuv.x = 1.0 - cuv.x;
      return texture2D(uCam, cuv).rgb * uCamBright;
    }

    void main() {
      vec2 uv = vUv;

      // Compute Osc2 first so it can modulate Osc1 (FM/PM)
      float c2 = axisCoord(uv, uO2.y);
      float o2raw = wave(c2 * uO2.z * TAU + uO2.w, uO2.x);
      float o2 = o2raw * uO2Amp;
      o2 = o2 * 0.5 + 0.5;

      // Osc1 with optional phase modulation from Osc2
      float c1 = axisCoord(uv, uO1.y);
      float fmPhase = uFmOn > 0.5 ? o2raw * uFmAmt * TAU : 0.0;
      float o1 = wave(c1 * uO1.z * TAU + uO1.w + fmPhase, uO1.x) * uO1Amp;
      o1 = o1 * 0.5 + 0.5;

      // Apply contrast/brightness per oscillator
      o1 = clamp(((o1 - 0.5) * uContrast + 0.5) * uBright, 0.0, 1.0);
      o2 = clamp(((o2 - 0.5) * uContrast + 0.5) * uBright, 0.0, 1.0);

      // Each oscillator carries its own hue
      vec3 col1 = hsv2rgb(vec3(uO1Hue, 1.0, 1.0)) * o1;
      vec3 col2 = hsv2rgb(vec3(uO2Hue, 1.0, 1.0)) * o2;

      // Mix between separate-oscillators and ring-mod (multiplied)
      vec3 ringMod = col1 * col2 * 2.0;

      // Background
      vec3 bg;
      if (uBgMode < 0.5) bg = vec3(1.0);
      else if (uBgMode < 1.5) bg = vec3(0.0);
      else bg = vec3(0.0, 0.694, 0.251);

      // Camera replaces or mixes with background in BG (1) or Both (3) mode
      if (uCamMode > 0.5 && (uCamMode < 1.5 || uCamMode > 2.5)) {
        vec3 camCol = sampleCamera(uv);
        bg = mix(bg, camCol, uCamMix);
      }

      // Blend the two colored oscillators
      vec3 combined;
      if (uBlendMode < 0.5) {
        // Add
        combined = col1 + col2;
      } else if (uBlendMode < 1.5) {
        // Subtract: start white, subtract each color (CMY-style)
        combined = vec3(1.0) - ((vec3(1.0) - col1) + (vec3(1.0) - col2));
      } else if (uBlendMode < 2.5) {
        // Screen
        combined = vec3(1.0) - (vec3(1.0) - col1) * (vec3(1.0) - col2);
      } else {
        // Multiply
        combined = col1 * col2 * 2.0;
      }

      // Apply oscMix to blend toward ring-mod
      combined = mix(combined, ringMod, uOscMix);
      combined = clamp(combined, 0.0, 1.0);

      // Composite over background. For white BG, invert so colors darken the white.
      vec3 col;
      if (uBgMode < 0.5) {
        // White bg: combined acts as "ink" — subtract from white
        col = bg - combined;
      } else if (uBgMode < 1.5) {
        // Black bg: combined is the light source — add to black
        col = bg + combined;
      } else {
        // Green bg: mix combined over green where it has presence
        float lum = max(max(combined.r, combined.g), combined.b);
        col = mix(bg, combined, lum);
      }
      col = clamp(col, 0.0, 1.0);

      // Feedback (with optional bloom)
      float fbAmt = uFbAmount;
      float fbExtraBright = 0.0;
      vec3 fbColTint = vec3(1.0);
      float bloomBoost = uBloomActive * uBloomIntensity;
      if (bloomBoost > 0.001) {
        if (uBloomStyle < 0.5) {
          // WHITE: push feedback past unity and add white injection
          fbAmt = min(0.999, fbAmt + bloomBoost * 0.4);
          fbExtraBright = bloomBoost * 1.2;
        } else if (uBloomStyle < 1.5) {
          // COLOR: feedback gain + hue rotation + saturation pump
          fbAmt = min(0.999, fbAmt + bloomBoost * 0.35);
          fbColTint = hsv2rgb(vec3(fract(uTime * 0.5), 1.0, 1.0));
          fbColTint = mix(vec3(1.0), fbColTint * 1.6, bloomBoost);
          fbExtraBright = bloomBoost * 0.3;
        } else {
          // GEOM: amplify pattern structure without blowing out
          fbAmt = min(0.999, fbAmt + bloomBoost * 0.5);
          fbColTint = vec3(1.0 + bloomBoost * 0.6);
        }
      }
      if (fbAmt > 0.001) {
        vec2 fbUv = uv - 0.5;
        float cs = cos(uFbRot), sn = sin(uFbRot);
        fbUv = mat2(cs, -sn, sn, cs) * fbUv;
        fbUv /= uFbZoom;
        fbUv += 0.5;
        if (fbUv.x >= 0.0 && fbUv.x <= 1.0 && fbUv.y >= 0.0 && fbUv.y <= 1.0) {
          vec3 prev = texture2D(uPrev, fbUv).rgb;
          if (abs(uFbHue) > 0.001) prev = hueShift(prev, uFbHue);
          prev *= fbColTint;
          col = mix(col, prev, fbAmt);
        }
      }
      if (fbExtraBright > 0.001) col += vec3(fbExtraBright);
      col = clamp(col, 0.0, 1.0);

      gl_FragColor = vec4(col, 1.0);
    }
  `
});
const patternQuad = new THREE.Mesh(new THREE.PlaneGeometry(2, 2), patternMat);
patternScene.add(patternQuad);

// Scene 2: Rutt/Etra displaced mesh, viewing the pattern texture
const ruttScene = new THREE.Scene();
const ruttCamera = new THREE.PerspectiveCamera(45, w / h, 0.1, 100);
ruttCamera.position.set(0, 0, 2.4);
ruttCamera.lookAt(0, 0, 0);

// Two meshes sharing the same geometry: one solid, one wireframe
const MESH_RES = 160; // density of subdivision
const ruttGeo = new THREE.PlaneGeometry(2, 2, MESH_RES, MESH_RES);

const ruttUniforms = {
  uMap: { value: null },
  uDisp: { value: 0.6 },
  uTilt: { value: 0.45 },
  uRotZ: { value: 0 },
  uZoom: { value: 1.2 },
  uBgMode: { value: 1 },
  uCam: { value: null },
  uCamMode: { value: 0 },
  uCamMix: { value: 0.7 },
  uCamBright: { value: 1 },
  uCamMirror: { value: 0 },
  uCamAspect: { value: 1 },
  uScreenAspect: { value: 1 }
};

const ruttVertexShader = /* glsl */`
  varying vec2 vUv;
  varying float vLum;
  uniform sampler2D uMap;
  uniform sampler2D uCam;
  uniform float uCamMode;
  uniform float uCamMix;
  uniform float uCamBright;
  uniform float uCamMirror;
  uniform float uCamAspect;
  uniform float uScreenAspect;
  uniform float uDisp;
  uniform float uTilt;
  uniform float uRotZ;
  uniform float uZoom;

  vec3 sampleCameraV(vec2 uv) {
    vec2 cuv = uv;
    float screenA = uScreenAspect;
    float camA = uCamAspect;
    if (camA > screenA) {
      float scale = screenA / camA;
      cuv.x = (cuv.x - 0.5) * scale + 0.5;
    } else {
      float scale = camA / screenA;
      cuv.y = (cuv.y - 0.5) * scale + 0.5;
    }
    if (uCamMirror > 0.5) cuv.x = 1.0 - cuv.x;
    return texture2D(uCam, cuv).rgb * uCamBright;
  }

  void main() {
    vUv = uv;
    vec3 p = position * uZoom;

    // Base displacement from the oscillator pattern
    vec3 samp = texture2D(uMap, uv).rgb;
    float lum = dot(samp, vec3(0.299, 0.587, 0.114));

    // If camera is in Disp (2) or Both (3) mode, mix camera luminance into displacement
    if (uCamMode > 1.5) {
      vec3 camSamp = sampleCameraV(uv);
      float camLum = dot(camSamp, vec3(0.299, 0.587, 0.114));
      lum = mix(lum, camLum, uCamMix);
    }

    vLum = lum;
    p.z += (lum - 0.5) * uDisp * 2.0;

    // tilt around X
    float ct = cos(uTilt), st = sin(uTilt);
    p = vec3(p.x, p.y * ct - p.z * st, p.y * st + p.z * ct);
    // rotate around Z
    float cz = cos(uRotZ), sz = sin(uRotZ);
    p.xy = mat2(cz, -sz, sz, cz) * p.xy;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(p, 1.0);
  }
`;

const ruttSolidMat = new THREE.ShaderMaterial({
  uniforms: ruttUniforms,
  vertexShader: ruttVertexShader,
  fragmentShader: /* glsl */`
    precision highp float;
    varying vec2 vUv;
    varying float vLum;
    uniform sampler2D uMap;
    void main() {
      vec3 col = texture2D(uMap, vUv).rgb;
      gl_FragColor = vec4(col, 1.0);
    }
  `,
  side: THREE.DoubleSide
});

const ruttWireMat = new THREE.ShaderMaterial({
  uniforms: ruttUniforms,
  vertexShader: ruttVertexShader,
  fragmentShader: /* glsl */`
    precision highp float;
    varying vec2 vUv;
    varying float vLum;
    uniform sampler2D uMap;
    void main() {
      vec3 col = texture2D(uMap, vUv).rgb;
      gl_FragColor = vec4(col, 1.0);
    }
  `,
  wireframe: true,
  side: THREE.DoubleSide
});

const ruttSolidMesh = new THREE.Mesh(ruttGeo, ruttSolidMat);
const ruttWireMesh = new THREE.Mesh(ruttGeo, ruttWireMat);
ruttScene.add(ruttSolidMesh);
ruttScene.add(ruttWireMesh);
ruttSolidMesh.visible = false;
ruttWireMesh.visible = true;

