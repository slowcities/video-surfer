function openPopOut() {
  if (popOutWindow && !popOutWindow.closed) {
    popOutWindow.focus();
    return;
  }
  // CRITICAL: Set up the channel BEFORE opening the popup so we don't miss
  // the popup's 'hello' message (which it sends immediately on load).
  if (!popOutChannel) {
    popOutChannel = new BroadcastChannel(POP_CHANNEL_NAME);
    popOutChannel.onmessage = (e) => {
      if (e.data.type === 'hello') {
        document.getElementById('popOutStatus').textContent = 'Output window connected. Laptop preview off to save GPU.';
        document.getElementById('popOutStatus').style.color = '#7ac9b0';
        document.getElementById('popOutBtn').textContent = 'Output Active';
        document.getElementById('popOutBtn').style.background = 'rgba(122, 201, 176, 0.3)';
        enablePopOutMode();
      } else if (e.data.type === 'popoutClosing') {
        disablePopOutMode();
      }
    };
  }
  // Initial window size — user can resize and move freely
  const features = 'width=960,height=540,menubar=no,toolbar=no,location=no,status=no';
  popOutWindow = window.open('', 'analogVideoSynthOutput', features);
  if (!popOutWindow) {
    document.getElementById('popOutStatus').textContent = 'Popup blocked. Allow popups for this site and try again.';
    document.getElementById('popOutStatus').style.color = '#c97a7a';
    return;
  }
  popOutWindow.document.open();
  popOutWindow.document.write(POPOUT_HTML);
  popOutWindow.document.close();

  // Watch for the popup being closed manually
  const checkClosed = setInterval(() => {
    if (popOutWindow && popOutWindow.closed) {
      clearInterval(checkClosed);
      disablePopOutMode();
      popOutWindow = null;
    }
  }, 1000);

  // If main window closes, tell popup
  window.addEventListener('beforeunload', () => {
    if (popOutChannel) popOutChannel.postMessage({ type: 'closing' });
  });
}

// Pop-out mode: hide laptop canvas and shrink it so we're not rendering 2x.
// The canvas is still drawn into (required for the bitmap capture) but at a
// smaller size and hidden from the laptop screen so it costs almost nothing.
let popOutModeOn = false;
let preservedCanvasSize = null;
function enablePopOutMode() {
  if (popOutModeOn) return;
  popOutModeOn = true;
  preservedCanvasSize = { w: w, h: h };
  // Shrink the main canvas to the resolution we want to send to the popup.
  // 960x540 is a good default — popup window will upscale to its own size cheaply.
  const popW = 960, popH = 540;
  canvas.style.display = 'none';
  renderer.setSize(popW, popH, false);
  ruttCamera.aspect = popW / popH;
  ruttCamera.updateProjectionMatrix();
  // Also resize the offscreen pattern targets to match
  rtA.dispose(); rtB.dispose();
  w = popW; h = popH;
  rtA = makeRT(); rtB = makeRT();
}
function disablePopOutMode() {
  if (!popOutModeOn) return;
  popOutModeOn = false;
  canvas.style.display = '';
  document.getElementById('popOutStatus').textContent = '';
  document.getElementById('popOutBtn').textContent = 'Pop Out Visual';
  document.getElementById('popOutBtn').style.background = 'rgba(122, 201, 176, 0.15)';
  // Restore main-window rendering size
  if (preservedCanvasSize) {
    w = window.innerWidth;
    h = window.innerHeight;
    renderer.setSize(w, h, false);
    ruttCamera.aspect = w / h;
    ruttCamera.updateProjectionMatrix();
    rtA.dispose(); rtB.dispose();
    rtA = makeRT(); rtB = makeRT();
  }
}

document.getElementById('popOutBtn').addEventListener('click', openPopOut);

// Per-frame bitmap capture + broadcast (called from render loop)
// Fire-and-forget: don't await the bitmap, just skip frames if the previous
// capture is still in flight. Capped at ~30fps to halve readback overhead.
let popBitmapInFlight = false;
let popLastSendTime = 0;
const POP_MIN_INTERVAL_MS = 33; // ~30fps cap
function broadcastFrameIfPopOut(now) {
  if (!popOutWindow || popOutWindow.closed || !popOutChannel) return;
  if (popBitmapInFlight) return;
  if (now - popLastSendTime < POP_MIN_INTERVAL_MS) return;
  popLastSendTime = now;
  popBitmapInFlight = true;
  // Fire async without awaiting; the render loop continues immediately
  createImageBitmap(canvas).then(bitmap => {
    try {
      popOutChannel.postMessage({ type: 'frame', bitmap }, [bitmap]);
    } catch (e) {
      // Channel might have closed mid-send; close bitmap to free memory
      try { bitmap.close(); } catch (e2) {}
    }
    popBitmapInFlight = false;
  }).catch(() => {
    popBitmapInFlight = false;
  });
}


// Parameter smoothing for MIDI-driven changes. Smooths the visible-output values
// of selected params to mask 7-bit MIDI steps. UI sliders still snap to MIDI values
// instantly so the controller and screen stay in sync.
const smoothed = {};
const SMOOTH_PARAMS = [
  'osc1Freq', 'osc2Freq',     // wide log range
  'osc1Phase', 'osc2Phase',
  'fbAmount', 'fbZoom', 'fbRot',
  'ruttDisp', 'ruttTilt', 'ruttRot', 'ruttZoom',
  'fmAmt',
  'bassAmt', 'midAmt', 'trebAmt'
];
const SMOOTH_RATE = 0.18; // ~80ms time constant at 60fps
function smoothParams() {
  for (const id of SMOOTH_PARAMS) {
    const target = state[id];
    if (typeof target !== 'number') continue;
    if (smoothed[id] === undefined) smoothed[id] = target;
    smoothed[id] += (target - smoothed[id]) * SMOOTH_RATE;
    // Snap when within noise floor
    if (Math.abs(target - smoothed[id]) < Math.abs(target) * 0.0005 + 0.00001) {
      smoothed[id] = target;
    }
  }
}
// Helper that reads smoothed value if present, else raw state
function P(id) { return smoothed[id] !== undefined ? smoothed[id] : state[id]; }

// ---------- Render loop ----------
const startTime = performance.now();
let lastFrameTime = startTime;
let fpsAccum = 0;
let fpsLastUpdate = startTime;
let driftPhase1 = 0;
let driftPhase2 = 0;
let colorDriftPhase = 0; // accumulates hue drift for Osc2 when Clr Drift is active
const TAU = Math.PI * 2;
function frame() {
  const now = performance.now();
  const t = (now - startTime) / 1000;
  const dt = Math.min((now - lastFrameTime) / 1000, 0.1); // clamp to avoid jumps after tab switch
  lastFrameTime = now;

  // Smooth MIDI-driven (and other) parameter changes for analog feel
  smoothParams();

  // Accumulate independent drift phases (TAU per second at drift=1)
  driftPhase1 = (driftPhase1 + state.osc1Drift * dt * TAU) % (TAU * 1000);
  driftPhase2 = (driftPhase2 + state.osc2Drift * dt * TAU) % (TAU * 1000);

  // Osc2 color drift: borrow the pattern Drift rate(s) to cycle Osc2's hue.
  // Off=0, O1=use osc1Drift, O2=use osc2Drift, Both=sum. Hue is 0..1 per cycle,
  // and drift rate is cycles/sec, so we scale modestly so color cycles aren't dizzying.
  let clrRate = 0;
  if (state.osc2ClrDrift === 1) clrRate = state.osc1Drift;
  else if (state.osc2ClrDrift === 2) clrRate = state.osc2Drift;
  else if (state.osc2ClrDrift === 3) clrRate = state.osc1Drift + state.osc2Drift;
  colorDriftPhase = (colorDriftPhase + clrRate * dt * 0.5) % 1000;

  // Run LFOs
  // LFO rates are shaped logarithmically (see shapeRateHz) for fine low-end control.
  const l1 = lfo(t, shapeRateHz(state.lfo1Rate), state.lfo1Wave, 0) * state.lfo1Depth;
  const l2 = lfo(t, shapeRateHz(state.lfo2Rate), state.lfo2Wave, 1) * state.lfo2Depth;

  // Apply LFO routing
  let o1Freq = P('osc1Freq');
  let o2Freq = P('osc2Freq');
  let o1Phase = P('osc1Phase') + driftPhase1;
  let o2Phase = P('osc2Phase') + driftPhase2;
  let dispMod = 0;
  let rotMod = 0;
  let fbHueMod = 0;
  let fbZoomMod = 0;
  let fbAmtMod = 0;
  let fbRotMod = 0;
  let o1HueMod = 0;
  let o2HueMod = 0;

  // LFO 1 destinations: O1F / O1H / FBAMT / FBHUE
  if (state.lfo1Dest === 0) o1Freq *= (1 + l1);
  else if (state.lfo1Dest === 1) o1HueMod += l1;
  else if (state.lfo1Dest === 2) fbAmtMod += l1;
  else if (state.lfo1Dest === 3) fbHueMod += l1;

  // LFO 2 destinations: O2F / O2H / FBZM / FBROT
  if (state.lfo2Dest === 0) o2Freq *= (1 + l2);
  else if (state.lfo2Dest === 1) o2HueMod += l2;
  else if (state.lfo2Dest === 2) fbZoomMod += l2;
  else if (state.lfo2Dest === 3) fbRotMod += l2;

  // Audio reactivity
  updateAudio();
  let audioBright = 0;
  let audioFbBoost = 0;
  function applyBand(level, dest, amt) {
    const v = level * amt;
    if (dest === 0) dispMod += v;              // Disp
    else if (dest === 1) o1Freq *= (1 + v);    // O1F
    else if (dest === 2) audioFbBoost += v;    // FB
    else if (dest === 3) rotMod += v * Math.PI;// Rot
    else if (dest === 4) audioBright += v;     // Bright
  }
  applyBand(bassLvl, state.bassDest, P('bassAmt'));
  applyBand(midLvl, state.midDest, P('midAmt'));
  applyBand(trebLvl, state.trebDest, P('trebAmt'));

  // Update uniforms
  patternMat.uniforms.uTime.value = t;
  patternMat.uniforms.uO1.value.set(state.osc1Wave, state.osc1Axis, o1Freq, o1Phase);
  patternMat.uniforms.uO1Amp.value = state.osc1Amp;
  patternMat.uniforms.uO2.value.set(state.osc2Wave, state.osc2Axis, o2Freq, o2Phase);
  patternMat.uniforms.uO2Amp.value = state.osc2Amp;
  patternMat.uniforms.uOscMix.value = state.oscMix;
  // Oscillator hue, with optional LFO modulation. Hue wraps 0..1 around the color
  // wheel, so we use modulo to cycle smoothly rather than clamp. Scale of 0.5 means
  // a full-depth LFO sweeps up to half the color wheel each direction.
  let o1h = state.osc1Hue + o1HueMod * 0.5;
  let o2h = state.osc2Hue + o2HueMod * 0.5 + (state.osc2ClrDrift > 0 ? colorDriftPhase : 0);
  o1h = ((o1h % 1) + 1) % 1;
  o2h = ((o2h % 1) + 1) % 1;
  patternMat.uniforms.uO1Hue.value = o1h;
  patternMat.uniforms.uO2Hue.value = o2h;
  patternMat.uniforms.uBlendMode.value = state.blendMode;
  patternMat.uniforms.uBgMode.value = state.bgMode;
  patternMat.uniforms.uBright.value = state.bright + audioBright;
  patternMat.uniforms.uContrast.value = state.contrast;
  // LFO1 -> FBAMT modulates feedback amount around the user's set value (plus any
  // audio boost). Scale 0.3 gives a strong but controlled swell; clamped to valid range.
  patternMat.uniforms.uFbAmount.value = Math.max(0, Math.min(0.99, P('fbAmount') + audioFbBoost + fbAmtMod * 0.3));
  // LFO2 -> FBZM modulates feedback zoom around the user's set value. Scale is small
  // because fbZoom is already in tight 0.85-1.15 territory and big swings would freeze
  // the loop. 0.05 here gives a noticeable but musically-useful sweep.
  patternMat.uniforms.uFbZoom.value = P('fbZoom') + fbZoomMod * 0.05;
  // LFO2 -> FBROT modulates feedback rotation. fbRot is in -0.15..0.15; scale to taste.
  patternMat.uniforms.uFbRot.value = P('fbRot') + fbRotMod * 0.06;
  // LFO1 -> FBHUE modulates the feedback hue shift. The fbHue param is already in
  // -0.05..0.05 (one cycle = full color wheel rotation), so we scale LFO accordingly.
  patternMat.uniforms.uFbHue.value = state.fbHue + fbHueMod * 0.05;
  patternMat.uniforms.uPrev.value = rtB.texture;

  // Video-input uniforms — works for both camera and video-file sources.
  updateVideoFile();
  // Mirror only applies to camera; video files shouldn't be mirrored by the auto rule
  const resolvedMirror = state.vidSrc === 1
    ? (state.camMirror === 1 ? 1 : 0)  // video: only mirror if explicitly On
    : (state.camMirror === -1 ? (state.camFacing === 1 ? 1 : 0) : state.camMirror);
  const camAspect = getActiveVideoAspect();
  const screenAspect = w / h;
  // Active only if the current source is actually available
  const sourceReady = state.vidSrc === 0 ? camActive : fileVidLoaded;
  const camModeVal = sourceReady ? state.camMode : 0;
  patternMat.uniforms.uCamMode.value = camModeVal;
  patternMat.uniforms.uCamMix.value = state.camMix;
  patternMat.uniforms.uCamBright.value = state.camBright;
  patternMat.uniforms.uCamMirror.value = resolvedMirror;
  patternMat.uniforms.uCamAspect.value = camAspect;
  patternMat.uniforms.uScreenAspect.value = screenAspect;
  ruttUniforms.uCamMode.value = camModeVal;
  ruttUniforms.uCamMix.value = state.camMix;
  ruttUniforms.uCamBright.value = state.camBright;
  ruttUniforms.uCamMirror.value = resolvedMirror;
  ruttUniforms.uCamAspect.value = camAspect;
  ruttUniforms.uScreenAspect.value = screenAspect;

  // FM. LFO1 always also modulates FM depth, scaled by the FM Mod slider —
  // independent of LFO1's assignable Dest. At fmMod=0 this does nothing.
  // l1 is already LFO1 output * its depth; we scale the swing to the FM Amt range (0-3).
  let fmDepth = P('fmAmt') + l1 * state.fmMod * 1.5;
  fmDepth = Math.max(0, fmDepth);
  patternMat.uniforms.uFmOn.value = state.fmOn;
  patternMat.uniforms.uFmAmt.value = fmDepth;

  // Bloom: smooth attack (fast) and release (medium) for analog feel
  const bloomAttack = 0.35;   // higher = faster onset
  const bloomRelease = 0.12;  // higher = faster decay
  const rate = bloomTarget > bloomActive ? bloomAttack : bloomRelease;
  bloomActive += (bloomTarget - bloomActive) * rate;
  if (bloomActive < 0.001) bloomActive = 0;
  patternMat.uniforms.uBloomActive.value = bloomActive;
  patternMat.uniforms.uBloomStyle.value = state.bloomStyle;
  patternMat.uniforms.uBloomIntensity.value = state.bloomIntensity;

  // Render pattern to rtA
  renderer.setRenderTarget(rtA);
  renderer.render(patternScene, patternCamera);

  // Update rutt uniforms
  ruttUniforms.uMap.value = rtA.texture;
  ruttUniforms.uDisp.value = P('ruttDisp') + dispMod;
  ruttUniforms.uTilt.value = P('ruttTilt');
  ruttUniforms.uRotZ.value = P('ruttRot') + rotMod;
  ruttUniforms.uZoom.value = P('ruttZoom');
  flatMat.uniforms.uMap.value = rtA.texture;

  // Render to screen
  renderer.setRenderTarget(null);

  // Background clear color based on mode
  if (state.bgMode === 0) renderer.setClearColor(0xffffff, 1);
  else if (state.bgMode === 1) renderer.setClearColor(0x000000, 1);
  else renderer.setClearColor(0x00b140, 1);
  renderer.clear();

  if (state.ruttMode === 2) {
    renderer.render(flatScene, flatCam);
  } else {
    renderer.render(ruttScene, ruttCamera);
  }

  // Swap for feedback only if it might be read next frame
  // (when feedback amount is 0 and bloom is inactive, no read happens)
  const fbInUse = state.fbAmount > 0.001 || bloomActive > 0.001;
  if (fbInUse) {
    const tmp = rtA; rtA = rtB; rtB = tmp;
  }

  // Send to pop-out window if active (fire-and-forget, no blocking)
  broadcastFrameIfPopOut(now);

  // FPS counter (smoothed)
  fpsAccum++;
  if (now - fpsLastUpdate > 500) {
    const fps = fpsAccum / ((now - fpsLastUpdate) / 1000);
    const el = document.getElementById('fpsDisplay');
    if (el) {
      el.textContent = 'FPS: ' + fps.toFixed(1) + (popOutWindow && !popOutWindow.closed ? '  ·  out: ~30' : '');
      el.style.color = fps < 30 ? '#c97a7a' : (fps < 50 ? '#c9a87a' : '#7ac9b0');
    }
    fpsAccum = 0;
    fpsLastUpdate = now;
  }

  requestAnimationFrame(frame);
}
updateRuttMode();
frame();
</script>
</body>
</html>
